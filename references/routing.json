{
  "_meta": {
    "schema_version": "2.0",
    "source": "REDESIGN-PLAN §2 (조각 02-routing-matrix.md) — 2026-07-04 Phase 0 동결",
    "canvas": { "standard": "4:5", "px": [1080, 1350], "derived_profiles": ["9:16"] },
    "signature": "route(archetype_id, tier, has_real_photo) → {hier_level, layer_count, image_pattern, type_band, emphasis_budget, accent_colors, reading_flow}"
  },
  "bands": {
    "BAND-COVER":   { "headline_px": [160, 300], "sub_px": [46, 60], "kicker_px": [38, 44], "weight": 900, "lh": [1.1, 1.3], "tracking": "-0.03em" },
    "BAND-BIGNUM":  { "number_px": [400, 650], "label_px": [80, 120], "caption_px": [38, 48], "weight": 900 },
    "BAND-DENSE":   { "layers": {
        "L0": { "px": [26, 32], "w": 700, "color": "accent", "device": "pill" },
        "L1": { "px": [60, 84], "w": 800, "color": "ink",    "device": "underline-bar" },
        "L2": { "px": [40, 48], "w": 450, "color": "ink80",  "chars_per_line": [16, 24], "lh": 1.6 },
        "L3": { "px": "=L2",    "w": 800, "color": "accent", "device": "highlighter", "max": 2 },
        "L4": { "px": [30, 36], "w": 450, "color": "gray60", "device": "indent" },
        "L5": { "px": [28, 32], "w": 450, "color": "gray50", "device": "rule-above", "prefix": "출처:" }
      },
      "size_ratio": { "L1:L2": 1.5, "L2:L5": 1.5 }, "ink_decay": ["100%", "80%", "60%", "50%"] },
    "BAND-MID":     { "headline_px": [80, 120], "body_px": [52, 72], "lh": 1.45 },
    "BAND-QUOTE":   { "quote_px": [76, 104], "attr_px": [36, 46], "lh": 1.35 },
    "BAND-LIST":    { "item_head_px": [60, 80], "item_body_px": [40, 52], "marker_scale": 1.3 },
    "BAND-CAPTION": { "caption_px": [46, 60], "source_px": [28, 36], "weight": 700, "lh": 1.4 }
  },
  "floors": { "body_px": 37, "caption_px": 24, "source_px": 28 },
  "archetypes": {
    "A1":  { "name": "cover", "type": "cover", "hier_level": "low", "layer_count": [1, 2],
             "type_band": "BAND-COVER", "emphasis_budget": 1, "accent_colors": 1, "reading_flow": "Z",
             "image_pattern": { "default": "A", "no_photo": "D", "alt": "B" },
             "scrim_zone_bbox": [0, 675, 1080, 1350], "image_required": true, "f_forbidden": true },
    "A2":  { "name": "toc", "type": "toc", "hier_level": "mid", "layer_count": [2, 3],
             "type_band": "BAND-MID", "type_band_secondary": "BAND-LIST",
             "emphasis_budget": 1, "accent_colors": 1, "reading_flow": "F",
             "image_pattern": { "default": "E", "no_photo": "E", "alt": "F" } },
    "A3":  { "name": "text-dense", "type": "body", "body_mode": "dense", "hier_level": "high", "layer_count": [3, 5],
             "type_band": "BAND-DENSE", "emphasis_budget": 2, "accent_colors": 1, "reading_flow": "F",
             "image_pattern": { "default": "G", "no_photo": "D", "alt": "F" },
             "reading_zone_bbox": [90, 220, 950, 1130] },
    "A4":  { "name": "big-number", "type": "stat", "viz_kind": "number", "hier_level": "mid", "layer_count": [2, 3],
             "type_band": "BAND-BIGNUM", "emphasis_budget": 1, "accent_colors": 1, "reading_flow": "center",
             "image_pattern": { "default": "F", "no_photo": "F", "alt": "E" },
             "_note": "이미지 강요 금지 — F(빅넘버 타이포)가 더 강함(§2.2 확정)" },
    "A5":  { "name": "list-bullet", "type": "body", "body_mode": "list", "hier_level": "mid", "layer_count": [3, 4],
             "type_band": "BAND-LIST", "emphasis_budget": 1, "accent_colors": 1, "reading_flow": "F",
             "image_pattern": { "default": "E", "no_photo": "E", "alt": "D" },
             "_note": "마커는 T3(구획) 장치 — 강조 예산 밖" },
    "A6":  { "name": "quote", "type": "quote", "hier_level": "low", "layer_count": [1, 2],
             "type_band": "BAND-QUOTE", "emphasis_budget": 1, "accent_colors": 1, "reading_flow": "center",
             "image_pattern": { "default": "F", "no_photo": "F", "alt": "A" },
             "_note": "이미지 강요 금지 — TYPOGRAPHY ONLY 우선(D4), alt A는 무드 배경 한정" },
    "A7":  { "name": "comparison-vs", "type": "comparison", "hier_level": "high", "layer_count": [3, 5],
             "type_band": "BAND-MID", "layout": "two-column", "emphasis_budget": 2, "accent_colors": 2,
             "reading_flow": "split-symmetric",
             "image_pattern": { "default": "E", "no_photo": "E", "alt": "G" },
             "_note": "강조 양 진영 각 1 = 예산 2, accent 2색 — D3 단일 accent의 role 기능상 의도적 예외(§2.2)" },
    "A8":  { "name": "timeline-steps", "type": "timeline", "hier_level": "mid", "layer_count": [3, 4],
             "type_band": "BAND-MID", "type_band_secondary": "BAND-LIST",
             "emphasis_budget": 1, "accent_colors": 1, "reading_flow": "left-axis",
             "image_pattern": { "default": "E", "no_photo": "E", "alt": "D" },
             "_note": "노드 번호는 T3 장치 — 예산 밖" },
    "A9":  { "name": "qna", "type": "body", "body_mode": "qa", "hier_level": "mid", "layer_count": [2, 3],
             "type_band": "BAND-MID", "type_band_answer": "BAND-DENSE",
             "emphasis_budget": 1, "accent_colors": 1, "reading_flow": "center-then-F",
             "image_pattern": { "default": "F", "no_photo": "D", "alt": "A" },
             "_note": "Q&A 도입 카드에 실사 있으면 A(§2.3 A9도입→A)" },
    "A10": { "name": "image-caption", "type": "image", "hier_level": "low", "layer_count": [2, 3],
             "type_band": "BAND-CAPTION", "emphasis_budget": 1, "accent_colors": 1, "reading_flow": "bottom-band",
             "image_pattern": { "default": "A", "no_photo": "C", "alt": "G" },
             "image_required": true, "f_forbidden": true,
             "_note": "밸리로는 brief.image_slot 사전예약 시에만 선택 가능(§5.4)" },
    "A11": { "name": "ending-cta", "type": "cta", "hier_level": "low", "layer_count": [2, 3],
             "type_band": "BAND-MID", "device": "pill", "emphasis_budget": 1, "accent_colors": 1,
             "reading_flow": "Z-golden-spot",
             "image_pattern": { "default": "F", "no_photo": "F", "alt": "B" },
             "_note": "이미지 강요 금지 — 미니멀 타이포+로고 1순위(D4 cta_end)" },
    "A12": { "name": "bridge", "type": "hook", "body_mode": "bridge", "hier_level": "low", "layer_count": [1, 2],
             "type_band": "BAND-COVER", "band_scale": 0.6, "emphasis_budget": 1, "accent_colors": 1,
             "reading_flow": "center",
             "image_pattern": { "default": "F", "no_photo": "F", "alt": "A" },
             "_note": "alt A는 딤 처리 사진 한정" },
    "A13": { "name": "comic-mascot", "type": "body", "body_mode": "comic", "hier_level": "mid", "layer_count": [2, 3],
             "type_band": "BAND-MID", "device": "speech-bubble", "emphasis_budget": 1, "accent_colors": 1,
             "reading_flow": "panel",
             "image_pattern": { "default": "B", "no_photo": "B", "alt": "C" },
             "image_required": true, "f_forbidden": true,
             "_note": "마스코트 컷아웃 필수 — 캐릭터 티어 전용 성격" },
    "A14": { "name": "infographic-chart", "type": "stat", "viz_kind": "chart", "hier_level": "high", "layer_count": [3, 5],
             "type_band": "BAND-MID", "device": "data-labels", "emphasis_budget": 2, "accent_colors": 3,
             "reading_flow": "chart-center",
             "image_pattern": { "default": "E", "no_photo": "E", "alt": "C" },
             "chart_medium": "CSS/SVG",
             "_note": "색코딩 accent 2~3 — D3 단일 accent의 의도적 예외(§2.2). 차트는 코드 드로잉(생성 아님)" }
  },
  "photo_branch": {
    "_rule": "1차 분기 — 티어보다 먼저 적용(§2.3)",
    "has_real_photo": { "A1": "A", "A10": "A", "A9_intro": "A", "A3": "G" },
    "no_photo":       { "A1": "D|C", "A10": "C", "A3": "D", "A4": "F" },
    "tone_hint": { "news_current": ["A", "G"], "knowledge_concept": ["C", "D", "E", "F"] }
  },
  "tier_override": {
    "luxury":    { "pattern_reroute": { "D": "A" },
                   "bundle": { "A": { "overlay_pct": [45, 65], "duotone": true, "lighting": "moody-golden" },
                               "B": { "shadow": "drop-float", "role": "hero-1/3" },
                               "E": { "style": "line-art" }, "fonts": "serif+black-gothic" } },
    "character": { "pattern_reroute": { "A": "D" },
                   "bundle": { "D": { "style": "pastel-blob+washi" }, "B": { "subject": "mascot", "role": "side-1/3" },
                               "C": { "style": "clay" }, "E": { "style": "flat-cartoon" }, "fonts": "round-gothic" },
                   "_note": "UGC 실사 허용 여부 미확정(§9 O11 — 기본 배타, 파일럿 A/B)" },
    "brand":     { "pattern_reroute": { "A": "G" },
                   "bundle": { "G": { "top": "clean-photo-or-data" }, "B": { "shadow": "contact", "subject": "product-or-3d" },
                               "C": { "style": "glossy-jelly" }, "E": { "style": "unified-set" }, "fonts": "geometric-sans" } },
    "news":      { "pattern_reroute": { "D": "A" },
                   "bundle": { "A": { "overlay_pct": [30, 50], "desaturate": true, "lighting": "documentary-flat" },
                               "B": { "shadow": "drop-flat", "role": "side-accent" },
                               "E": { "style": "line-icon+pill" }, "fonts": "gothic-black+grotesque-bold" },
                   "_note": "뉴닉형 — 사진 활용형(luxury D→A 로직 참고), 채도 죽인 다큐 사진 위 형광오렌지 밴드" },
    "editorial": { "pattern_reroute": { "D": "A", "E": "G" },
                   "bundle": { "A": { "overlay_pct": [55, 75], "style": "lifestyle-still-life", "caption": "bottom-left-2-line" },
                               "B": { "shadow": "soft-natural", "role": "hero-full" },
                               "G": { "top": "clean-photo-minimal-text" }, "fonts": "rounded-serif-gungseo+grotesque-regular" },
                   "_note": "디에디트형 — A/G 사진 위주 reroute(D/E 흡수), 텍스트 최소·이미지 히어로" },
    "data":      { "pattern_reroute": { "A": "D", "G": "F" },
                   "bundle": { "D": { "style": "3d-glossy-candy-icon" },
                               "B": { "shadow": "soft-rim-glow", "subject": "candy-icon-or-chart", "role": "grid-3xn" },
                               "E": { "style": "flat-chart-line" }, "fonts": "rounded-display+geometric-sans" },
                   "_note": "뱅크샐러드형 — D/F 위주 reroute(A/G 흡수), 3D 캔디 아이콘·데이터 타이포 우선" },
    "newsprint": { "pattern_reroute": { "A": "G" },
                   "bundle": { "G": { "top": "documentary-photo-or-portrait", "corner": "square" },
                               "D": { "style": "flat-black-outline-icon" },
                               "E": { "style": "line-icon+pill" }, "fonts": "condensed-black-poster+grotesque-bold" },
                   "_note": "굿굿굿 뉴스프린트형 — A(풀블리드+하단캡션 오버레이)를 G(상단 55% 사진블록+본문 좌정렬)로 통째 대체(원본에 풀블리드 스크림 캡션 패턴 없음). 커버(A1)는 무photo 포스터가 기본(D)이라 reroute 대상 아님" }
  },
  "density_wave": {
    "high": ["A3", "A7", "A14"], "mid": ["A2", "A4", "A5", "A8", "A9", "A13"], "low": ["A1", "A6", "A10", "A11", "A12"],
    "max_consecutive_high": 3, "max_consecutive_same_archetype": 3, "valley_pool": ["A4", "A6", "A10", "A12"],
    "front_slot": ["A1"], "front_optional": ["A2", "A12"], "end_slot": ["A11"], "end_optional": ["A6"],
    "consistency_rail": ["palette", "fonts", "margin", "logo_pos", "page_indicator"], "no_repeat_field": "image_pattern"
  },
  "override_order": [
    "1. archetype_default_pattern = archetypes[id].image_pattern.default",
    "2. pattern = photo_branch(default, has_real_photo)",
    "3. pattern = tier_override[tier].pattern_reroute[pattern]  (3셀만: luxury D→A, character A→D, brand A→G)",
    "4. realize = tier_override[tier].bundle[pattern]"
  ]
}
